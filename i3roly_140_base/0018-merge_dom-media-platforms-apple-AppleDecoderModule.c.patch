 /* static */
 void AppleDecoderModule::Init() {
   if (sInitialized) {
     return;
   }
 
+  //10.7.3 - > 10.7 need these (thanks jya)
+  sIsCoreMediaAvailable = AppleCMLinker::Link();
+  sIsCoreVideoAvailable = AppleCVLinker::Link();
+  sIsVDAAvailable = AppleVDALinker::Link();
