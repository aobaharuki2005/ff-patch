-    // Setup the "double tap" event.
-    WidgetSimpleGestureEvent geckoEvent(true, eTapGesture, mGeckoChild);
-    [self convertCocoaMouseEvent:anEvent toGeckoEvent:&geckoEvent];
-    geckoEvent.mClickCount = 1;
