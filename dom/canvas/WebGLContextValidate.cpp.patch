+++ b/dom/canvas/WebGLContextValidate.cpp
@@ -27,6 +27,10 @@
 #include "mozilla/StaticPrefs_webgl.h"
 #include "nsPrintfCString.h"
 
+#if defined(MOZ_WIDGET_COCOA)
+#  include "nsCocoaFeatures.h"
